[Default Applications]
# Web
x-scheme-handler/bitwarden=bitwarden.desktop
x-scheme-handler/http=firefox.desktop
x-scheme-handler/https=firefox.desktop
text/html=firefox.desktop
application/xhtml+xml=firefox.desktop
application/x-extension-html=firefox.desktop
application/x-extension-htm=firefox.desktop
application/x-extension-shtml=firefox.desktop
application/x-extension-xhtml=firefox.desktop
application/x-extension-xht=firefox.desktop
x-scheme-handler/chrome=firefox.desktop

# PDF
application/pdf=firefox.desktop

# Text
text/plain=kitty.desktop
text/x-makefile=kitty.desktop
text/x-c=kitty.desktop
text/x-c++=kitty.desktop
text/x-python=kitty.desktop
application/x-shellscript=kitty.desktop
application/json=kitty.desktop
application/x-perl=kitty.desktop
text/x-rust=kitty.desktop

# Images
image/*=org.kde.gwenview.desktop

# Video
video/*=mpv.desktop

# Audio
audio/*=mpv.desktop

# File manager / directories
inode/directory=pcmanfm-qt.desktop

# Archives
application/zip=pcmanfm-qt.desktop
application/x-tar=pcmanfm-qt.desktop
application/gzip=pcmanfm-qt.desktop
application/x-bzip=pcmanfm-qt.desktop
application/x-bzip2=pcmanfm-qt.desktop
application/x-xz=pcmanfm-qt.desktop
application/x-7z-compressed=pcmanfm-qt.desktop
application/x-rar=pcmanfm-qt.desktop
application/x-compressed-tar=pcmanfm-qt.desktop
application/x-tarz=pcmanfm-qt.desktop
